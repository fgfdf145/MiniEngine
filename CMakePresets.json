{
    "version": 3,
    "configurePresets": [
        {
            "name": "windows-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/.deps/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_MANIFEST_MODE": "ON",
                "VCPKG_INSTALLED_DIR": "${sourceDir}/.deps/vcpkg_installed"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "windows-vs-base",
            "hidden": true,
            "generator": "Visual Studio 18 2026",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/.deps/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_MANIFEST_MODE": "ON",
                "VCPKG_INSTALLED_DIR": "${sourceDir}/.deps/vcpkg_installed"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "x64-debug",
            "displayName": "x64 Debug",
            "inherits": "windows-base",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "VCPKG_TARGET_TRIPLET": "x64-windows"
            }
        },
        {
            "name": "x64-release",
            "displayName": "x64 Release",
            "inherits": "x64-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "vs2026-x64",
            "displayName": "Visual Studio 2026 x64",
            "inherits": "windows-vs-base",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows"
            }
        },
        {
            "name": "x86-debug",
            "displayName": "x86 Debug",
            "inherits": "windows-base",
            "architecture": {
                "value": "x86",
                "strategy": "external"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "VCPKG_TARGET_TRIPLET": "x86-windows"
            }
        },
        {
            "name": "x86-release",
            "displayName": "x86 Release",
            "inherits": "x86-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "vs2026-x86",
            "displayName": "Visual Studio 2026 x86",
            "inherits": "windows-vs-base",
            "architecture": {
                "value": "Win32",
                "strategy": "set"
            },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x86-windows"
            }
        },
        {
            "name": "linux-debug",
            "displayName": "Linux Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/.deps/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_MANIFEST_MODE": "ON",
                "VCPKG_INSTALLED_DIR": "${sourceDir}/.deps/vcpkg_installed"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "vendor": {
                "microsoft.com/VisualStudioRemoteSettings/CMake/1.0": {
                    "sourceDir": "$env{HOME}/.vs/$ms{projectDirName}"
                }
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-build-base",
            "hidden": true,
            "environment": {
                "CMAKE_BUILD_PARALLEL_LEVEL": "$penv{NUMBER_OF_PROCESSORS}"
            }
        },
        {
            "name": "x64-debug",
            "displayName": "x64 Debug Build",
            "configurePreset": "x64-debug",
            "inherits": "windows-build-base"
        },
        {
            "name": "x64-release",
            "displayName": "x64 Release Build",
            "configurePreset": "x64-release",
            "inherits": "windows-build-base"
        },
        {
            "name": "vs2026-x64-debug",
            "displayName": "Visual Studio 2026 x64 Debug Build",
            "configurePreset": "vs2026-x64",
            "configuration": "Debug",
            "inherits": "windows-build-base"
        },
        {
            "name": "vs2026-x64-release",
            "displayName": "Visual Studio 2026 x64 Release Build",
            "configurePreset": "vs2026-x64",
            "configuration": "Release",
            "inherits": "windows-build-base"
        },
        {
            "name": "x86-debug",
            "displayName": "x86 Debug Build",
            "configurePreset": "x86-debug",
            "inherits": "windows-build-base"
        },
        {
            "name": "x86-release",
            "displayName": "x86 Release Build",
            "configurePreset": "x86-release",
            "inherits": "windows-build-base"
        },
        {
            "name": "vs2026-x86-debug",
            "displayName": "Visual Studio 2026 x86 Debug Build",
            "configurePreset": "vs2026-x86",
            "configuration": "Debug",
            "inherits": "windows-build-base"
        },
        {
            "name": "vs2026-x86-release",
            "displayName": "Visual Studio 2026 x86 Release Build",
            "configurePreset": "vs2026-x86",
            "configuration": "Release",
            "inherits": "windows-build-base"
        },
        {
            "name": "linux-debug",
            "displayName": "Linux Debug Build",
            "configurePreset": "linux-debug"
        }
    ]
}
